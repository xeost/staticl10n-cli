{
  "name": "staticl10n",
  "version": "0.1.0",
  "description": "CLI tool to capture websites, convert them to static content and translate them into multiple languages",
  "type": "module",
  "bin": {
    "staticl10n": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "preview:tailwindcss-local:original": "npx wrangler pages dev temp-public-static/tailwindcss-local/original"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "domhandler": "^6.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^10.1.8",
    "ora": "^8.1.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
