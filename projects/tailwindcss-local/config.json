{
  "name": "TailwindCSS Local",
  "slug": "tailwindcss-local",
  "url": "http://localhost:3002",
  "targetUrls": {
    "es": "tailwindcss.esdocu.com"
  },
  "siteType": "nextjs",
  "crawl": {
    "delayMs": 10,
    "delayJitterMs": 500,
    "maxPages": 500,
    "ignorePatterns": ["/blog", "/plus"],
    "normalizeTrailingSlash": true,
    "stripQueryParams": true
  },
  "paths": {
    "original": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/tailwindcss-local/original",
    "raw": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/tailwindcss-local/raw",
    "translations": {
      "es": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/tailwindcss-local/es"
    }
  },
  "translation": {
    "provider": "ollama",
    "ollamaUrl": "http://localhost:11434",
    "model": "gemma4",
    "sourceLanguage": "en",
    "targetLanguages": [
      "es"
    ],
    "batchSize": 20,
    "maxFragmentTokens": 1200,
    "maxRetries": 5,
    "cacheExpiry": -1,
    "context": "Official documentation website for Tailwind CSS, a utility-first CSS framework.",
    "preserveTerms": ["Tailwind", "Tailwind CSS", "CSS", "HTML", "JavaScript", "TypeScript", "npm", "Vite", "PostCSS", "Autoprefixer", "PurgeCSS", "JIT", "CDN", "IntelliSense", "VSCode", "Prettier", "ESLint", "Sass", "SCSS", "React", "Vue", "Svelte", "Next.js", "Nuxt", "Laravel", "Rails", "Django"],
    "translateCodeBlocks": true
  },
  "personalization": {
    "preTranslation": [],
    "postTranslation": [
      {
        "type": "replace_text",
        "selector": "title",
        "search": "Tailwind CSS",
        "replace": "Tailwind CSS en Español",
        "languages": ["es"],
        "description": "Rename page titles for the Spanish translation"
      }
    ]
  },
  "copyAssetsMode": "copy"
}
