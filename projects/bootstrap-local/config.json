{
  "name": "Bootstrap Local",
  "slug": "bootstrap-local",
  "url": "http://localhost:9001",
  "targetUrls": {
    "es": "https://getbootstrap.esdocu.com"
  },
  "siteType": "generic",
  "crawl": {
    "delayMs": 1500,
    "delayJitterMs": 500,
    "maxPages": 500,
    "ignorePatterns": [],
    "normalizeTrailingSlash": true,
    "stripQueryParams": true,
    "postHydrationDelayMs": 800
  },
  "paths": {
    "original": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/bootstrap-local/original",
    "raw": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/bootstrap-local/raw",
    "translations": {
      "es": "/Users/fabian/Documents/CodeProjects/github.com/xeost/staticl10n-cli/temp-public-static/bootstrap-local/es"
    }
  },
  "translation": {
    "provider": "ollama",
    "ollamaUrl": "http://localhost:11434",
    "model": [
      "gemma4",
      "llama3.1"
    ],
    "sourceLanguage": "en",
    "targetLanguages": [
      "es"
    ],
    "batchSize": 20,
    "maxFragmentTokens": 2000,
    "maxRetries": 7,
    "cacheExpiry": -1,
    "context": "Official documentation website for Bootstrap, a popular open-source HTML/CSS/JS front-end framework.",
    "preserveTerms": [
      "Bootstrap",
      "Sass",
      "Parcel",
      "Webpack",
      "Vite",
      "Popper",
      "npm",
      "jsDelivr",
      "RFS",
      "Hugo",
      "jQuery",
      "Autoprefixer",
      "PostCSS"
    ],
    "translateCodeBlockComments": true
  },
  "personalization": {
    "preTranslation": [
      {
        "type": "remove_element",
        "selector": "script[src='https://cdn.usefathom.com/script.js']"
      },
      {
        "type": "remove_element",
        "selector": "script#_carbonads_js"
      },
      {
        "type": "remove_element",
        "selector": "#carbonads"
      }
    ],
    "postTranslation": [
      {
        "type": "replace_text",
        "selector": "head > title",
        "search": "Bootstrap",
        "replace": "Bootstrap en Español",
        "languages": [
          "es"
        ],
        "description": "Rename page titles for the Spanish translation"
      }
    ]
  },
  "copyAssetsMode": "copy",
  "pathRewrite": [],
  "domainMap": {}
}