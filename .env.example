# ─── Translation Provider API Keys ───────────────────────────────────────────
#
# Copy this file to .env and fill in the keys for the providers you use.
# The .env file is loaded automatically at startup (Node.js 20.12+).
# Never commit .env to version control.

# Google Gemini (used when translation.provider = "gemini")
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=

# OpenAI (reserved for future use)
# OPENAI_API_KEY=

# Mistral AI (reserved for future use)
# MISTRAL_API_KEY=

# Anthropic Claude (reserved for future use)
# ANTHROPIC_API_KEY=

# Detailed translation debug logs (saved under data/logs/)
# Set to true to generate a new debug log for each execution
# DEBUG_TRANSLATION_LOG=false
